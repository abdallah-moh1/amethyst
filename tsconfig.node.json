{
    "compilerOptions": {
        "target": "ES2022",
        "module": "NodeNext",
        "moduleResolution": "NodeNext",
        "rootDir": ".",
        "outDir": "dist-electron",
        "strict": true,
        "skipLibCheck": true,
        "composite": true,
        "resolveJsonModule": true,
        "types": [
            "node"
        ]
    },
    "include": [
        "electron/**/*.ts",
        "electron/**/*.mts",
        "electron/**/*.json",
        "shared/**/*.ts",
        "shared/**/*.json"
    ]
}