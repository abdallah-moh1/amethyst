{
    "compilerOptions": {
        "target": "ES2022",
        "module": "NodeNext",
        "moduleResolution": "NodeNext",
        "rootDir": "electron",
        "outDir": "dist-electron",
        "strict": true,
        "skipLibCheck": true,
        "composite": true,
        "types": [
            "node"
        ]
    },
    "include": [
        "electron/**/*.ts",
        "electron/**/*.mts"
    ]
}