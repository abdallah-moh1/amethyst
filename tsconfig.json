{
    "compilerOptions": {
        "target": "ES2020",
        "useDefineForClassFields": true,
        "lib": [
            "ES2020",
            "DOM",
            "DOM.Iterable"
        ],
        "allowJs": false,
        "skipLibCheck": true,
        "esModuleInterop": true,
        "allowSyntheticDefaultImports": true,
        "strict": true,
        "forceConsistentCasingInFileNames": true,
        "module": "ESNext",
        // "moduleResolution": "Node",
        "resolveJsonModule": true,
        "isolatedModules": true,
        "noEmit": true,
        "jsx": "react-jsx",
        // "baseUrl": ".",
        "paths": {
            "@shared/*": [
                "./shared/*"
            ],
            "@/*": [
                "./src/*"
            ]
        }
    },
    "include": [
        "src",
        "shared",
        "vite.config.ts",
    ],
    "exclude": [
        "dist",
        "dist-electron",
        "node_modules"
    ],
}