{
  "name": "amethyst",
  "productName": "Amethyst",
  "version": "0.1.0",
  "description": "Amethyst - A modern markdown note-taking application",
  "homepage": "https://github.com/abdallah-moh1/amethyst#readme",
  "bugs": {
    "url": "https://github.com/abdallah-moh1/amethyst/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/abdallah-moh1/amethyst.git"
  },
  "license": "AGPL-3.0-or-later",
  "author": "Abdallah Mohammad <abdallah.moh.q@gmail.com>",
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:renderer\" \"npm:dev:electron\"",
    "dev:renderer": "vite",
    "dev:electron": "wait-on tcp:5173 && tsc -p tsconfig.node.json && cross-env ELECTRON_START_URL=http://localhost:5173 electron .",
    "build": "tsc -p tsconfig.node.json && vite build",
    "preview": "vite preview"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^41.1.0",
    "typescript": "^6.0.2",
    "vite": "^8.0.3",
    "wait-on": "^9.0.4"
  },
  "dependencies": {
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  }
}